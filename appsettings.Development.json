{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FeatureFlags": {
    "UseMockRepositories": true
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "fulfillment-center-service",
    "Topics": {
      "FulfillmentCommands": "fulfillment.commands",
      "FulfillmentCapacityReserved": "fulfillment.capacity.reserved",
      "FulfillmentCapacityConfirmed": "fulfillment.capacity.confirmed",
      "FulfillmentCapacityFailed": "fulfillment.capacity.failed"
    }
  }
}
